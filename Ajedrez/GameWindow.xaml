<Window x:Class="Ajedrez.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Juego" Height="1000" Width="1000">
    <Grid>
        <!-- Tablero dentro de un Viewbox para que escale manteniendo proporciones -->
        <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Height="706" Width="706">
            <!-- UniformGrid con 8 filas y 8 columnas donde se dibujarán las casillas -->
            <UniformGrid x:Name="BoardGrid" Rows="8" Columns="8" Width="560" Height="560"/>
        </Viewbox>
        <Label x:Name="checksChecker" Content="ppppppp" HorizontalAlignment="Left" Margin="156,78,0,0" VerticalAlignment="Top" Height="41" Width="662" Foreground="#FF901515" FontSize="22"/>

    </Grid>
</Window>