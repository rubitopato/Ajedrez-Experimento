<Window x:Class="Ajedrez.PromotionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="220" Width="450"
        Background="#F4F6F8"
        WindowStartupLocation="CenterScreen"
        Title="Promoción">

	<Grid>

		<!-- Contenedor tipo tarjeta -->
		<Border Background="White"
                CornerRadius="15"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

			<StackPanel>

				<!-- Título -->
				<TextBlock Text="Elige una pieza"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#2C2C2C"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

				<!-- Botones de piezas -->
				<StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

					<!-- Reina -->
					<Button x:Name="QueenButton"
                            Width="80"
                            Height="80"
                            Margin="5"
                            Click="QueenButton_Click"
                            ToolTip="Reina"
                            Background="#EEEEEE"
                            BorderThickness="0"
                            Cursor="Hand">

						<Button.Style>
							<Style TargetType="Button">
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="Button">
											<Border CornerRadius="12"
                                                    Background="{TemplateBinding Background}">
												<ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
											</Border>
										</ControlTemplate>
									</Setter.Value>
								</Setter>

								<Style.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter Property="Background" Value="#DDDDDD"/>
									</Trigger>
									<Trigger Property="IsPressed" Value="True">
										<Setter Property="Background" Value="#CCCCCC"/>
									</Trigger>
								</Style.Triggers>
							</Style>
						</Button.Style>
					</Button>

					<!-- Torre -->
					<Button x:Name="RookButton"
                            Width="80"
                            Height="80"
                            Margin="5"
                            Click="RookButton_Click"
                            ToolTip="Torre"
                            Background="#EEEEEE"
                            BorderThickness="0"
                            Cursor="Hand"
                            Style="{StaticResource {x:Type Button}}"/>

					<!-- Alfil -->
					<Button x:Name="BishopButton"
                            Width="80"
                            Height="80"
                            Margin="5"
                            Click="BishopButton_Click"
                            ToolTip="Alfil"
                            Background="#EEEEEE"
                            BorderThickness="0"
                            Cursor="Hand"
                            Style="{StaticResource {x:Type Button}}"/>

					<!-- Caballo -->
					<Button x:Name="KnightButton"
                            Width="80"
                            Height="80"
                            Margin="5"
                            Click="KnightButton_Click"
                            ToolTip="Caballo"
                            Background="#EEEEEE"
                            BorderThickness="0"
                            Cursor="Hand"
                            Style="{StaticResource {x:Type Button}}"/>

				</StackPanel>

			</StackPanel>

		</Border>

	</Grid>
</Window>