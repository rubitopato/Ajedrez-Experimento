<Window x:Class="Ajedrez.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="800" Width="1000"
        Background="#F4F6F8"
        WindowStartupLocation="CenterScreen"
        Title="Ajedrez">

    <Grid>
        <!-- Definimos columnas para equilibrar el layout -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Botón a la izquierda, centrado verticalmente -->
        <Button x:Name="ResetButton"
                Grid.Column="0"
                Click="ResetButton_Click"
                Content="Reiniciar"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Height="70"
                Width="180"
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="White"
                Background="#4CAF50"
                BorderThickness="0"
                Cursor="Hand">

            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#4CAF50"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="12"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                    <!-- Efecto hover -->
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#45A049"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#3D8B40"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- Tablero centrado -->
        <Viewbox Grid.Column="1"
                 Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Height="700"
                 Width="700">

            <Border Background="#2C2C2C"
                    CornerRadius="15"
                    Padding="15">

                <UniformGrid x:Name="BoardGrid"
                             Rows="8"
                             Columns="8"
                             Width="560"
                             Height="560"/>
            </Border>

        </Viewbox>

    </Grid>
</Window>