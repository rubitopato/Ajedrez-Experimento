<Window x:Class="Ajedrez.PromotionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="150" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="QueenButton" Width="80" Height="80" Margin="5" Click="QueenButton_Click" ToolTip="Reina" />
            <Button x:Name="RookButton" Width="80" Height="80" Margin="5" Click="RookButton_Click" ToolTip="Torre" />
            <Button x:Name="BishopButton" Width="80" Height="80" Margin="5" Click="BishopButton_Click" ToolTip="Alfil" />
            <Button x:Name="KnightButton" Width="80" Height="80" Margin="5" Click="KnightButton_Click" ToolTip="Caballo" />
        </StackPanel>
    </Grid>
</Window>