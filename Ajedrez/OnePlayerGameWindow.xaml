<Window x:Class="Ajedrez.OnePlayerGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="1200" Width="1200">
    <Grid>
        <!-- Tablero dentro de un Viewbox para que escale manteniendo proporciones -->
        <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Height="750" Width="750">
            <!-- UniformGrid con 8 filas y 8 columnas donde se dibujarán las casillas -->
            <UniformGrid x:Name="BoardGrid" Rows="8" Columns="8" Width="560" Height="560"/>
        </Viewbox>
        <Button x:Name="ResetButton" Click="ResetButton_Click" Content="Reiniciar" HorizontalAlignment="Left" Margin="47,0,0,0" VerticalAlignment="Center" Height="100" Width="150" Foreground="Black" FontSize="22" Background="#FFA0EFC2"/>

    </Grid>
</Window>