<Window x:Class="Ajedrez.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Página de Inicio"
        Height="800" Width="1000"
        Background="#F4F6F8"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <!-- Contenedor central -->
        <Border Background="White"
                CornerRadius="20"
                Padding="40"
                Width="500"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel HorizontalAlignment="Center">

                <!-- Título -->
                <TextBlock Text="AJEDREZ"
                           FontSize="48"
                           FontWeight="Bold"
                           Foreground="#2C2C2C"
                           Margin="0,0,0,40"
                           HorizontalAlignment="Center"/>

                <!-- Botón 1 jugador -->
                <Button x:Name="one_player_play_button"
                        Content="J1 vs IA"
                        Click="one_player_play_button_Click"
                        Width="250"
                        Height="80"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Background="#4CAF50"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,20">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#4CAF50"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="15"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#45A049"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#3D8B40"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Botón 2 jugadores -->
                <Button x:Name="two_player_play_button"
                        Content="J1 vs J2"
                        Click="two_player_play_button_Click"
                        Width="250"
                        Height="80"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Background="#2196F3"
                        BorderThickness="0"
                        Cursor="Hand">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2196F3"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="15"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1E88E5"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#1565C0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>

        </Border>

    </Grid>
</Window>